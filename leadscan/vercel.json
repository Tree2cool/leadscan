{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/geocode", "dest": "/api/geocode.js" },
    { "src": "/api/places", "dest": "/api/places.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
